APP_ENV=development
APP_NAME=ai-post-generator
APP_HOST=127.0.0.1
APP_PORT=8000
REQUEST_TIMEOUT_SECONDS=60
HF_INFERENCE_BASE_URL=https://router.huggingface.co/hf-inference/models

# Required for live Hugging Face generation.
# You can set either HUGGINGFACE_API_KEY or HF_TOKENS.
HUGGINGFACE_API_KEY=
HF_TOKENS=
TEXT_MODEL_ID=google/flan-t5-large
IMAGE_MODEL_ID=runwayml/stable-diffusion-v1-5
